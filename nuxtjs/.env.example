# 管理后台登录用户名
ADMIN_USERNAME=admin

# 管理后台登录密码哈希（bcrypt）
# 生成示例：
# node -e "console.log(require('bcryptjs').hashSync('YourPassword', 12))"
# 注意：此处填写哈希值，不是明文密码
ADMIN_PASSWORD_HASH=

# 管理端 JWT 签名密钥
# 用途：签发/校验管理员登录态 Token
# 建议：使用足够长的随机字符串（建议 32 字符以上）
ADMIN_JWT_SECRET=2854c423a8ffb54645d097aa7c546682719a452eabc5e8d324431a9c2d48bec6
AUTH_JWT_SECRET=replace_with_auth_jwt_secret

# AI 调用鉴权 Key
# 用途：用于 /api/public/keys/create 的 x-api-key 校验
AI_API_KEY=ai_a6d079208962111ff1492be9d3a13a3af604984b2db132c0

# AI 调用签名密钥
# 用途：用于请求签名 x-signature 验证，防止伪造调用
AI_API_HMAC_SECRET=7f6a0dce9d4b51e63bd565270fd0759458b276014785a68d3dd7ffc655e7d89c

# ============================================================
# 支付配置（真实支付宝/微信）
# ============================================================
ALIPAY_APP_ID=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=

WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_API_V3_KEY=
WECHAT_SERIAL_NO=
WECHAT_PRIVATE_KEY=
WECHAT_NOTIFY_URL=

# ============================================================
# 推荐（Recommended）：有默认值，可按需调整
# ============================================================

# 激活请求允许的时钟偏差（秒）
# 用途：校验 timestamp 时允许客户端与服务端存在少量时间误差
ACTIVATE_CLOCK_SKEW_SECONDS=300

# 许可证有效期（秒）
# 示例：31536000 = 365 天
ACTIVATE_TOKEN_EXPIRES_SECONDS=31536000
