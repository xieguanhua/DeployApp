# PostgreSQL 连接串
# 用途：服务端连接激活数据库（存储产品、激活码、设备绑定等信息）
# 格式：postgres://<user>:<password>@<host>:<port>/<database>
PG_CONNECTION_STRING=postgres://postgres:15989449409@127.0.0.1:5432/activation_service

