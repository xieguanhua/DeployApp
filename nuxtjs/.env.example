PG_CONNECTION_STRING=postgres://postgres:postgres@127.0.0.1:5432/activation_service

# RSA私钥（PKCS8 PEM，多行内容可用 \n 拼接）
LICENSE_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----
# RSA公钥（SPKI PEM）
LICENSE_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----

ADMIN_USERNAME=admin
# 通过 `node -e "console.log(require('bcryptjs').hashSync('YourPassword', 12))"` 生成
ADMIN_PASSWORD_HASH=
ADMIN_JWT_SECRET=replace_with_long_random_secret

AI_API_KEY=replace_with_ai_api_key
AI_API_HMAC_SECRET=replace_with_hmac_secret

ACTIVATE_CLOCK_SKEW_SECONDS=300
ACTIVATE_TOKEN_EXPIRES_SECONDS=31536000
